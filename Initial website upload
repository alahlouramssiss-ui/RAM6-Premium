    function applyLang(lang){
      currentLang = lang;
      btnFR.classList.toggle("active", lang === "fr");
      btnEN.classList.toggle("active", lang === "en");

      // Toggle blocks
      document.querySelectorAll("[data-lang]").forEach(el=>{
        const elLang = el.getAttribute("data-lang");
        el.classList.toggle("on", elLang === lang);
      });

      // Update placeholders
      document.querySelectorAll("input[data-ph-fr], textarea[data-ph-fr]").forEach(el=>{
        el.placeholder = (lang === "fr") ? el.getAttribute("data-ph-fr") : el.getAttribute("data-ph-en");
      });

      // Update select first option labels if provided
      document.querySelectorAll("select").forEach(sel=>{
        const first = sel.querySelector("option[value='']");
        if(first){
          const fr = first.getAttribute("data-fr");
          const en = first.getAttribute("data-en");
          if(fr && en) first.textContent = (lang === "fr") ? fr : en;
        }
        // Update any option that has data-fr/en
        sel.querySelectorAll("option").forEach(opt=>{
          const fr = opt.getAttribute("data-fr");
          const en = opt.getAttribute("data-en");
          if(fr && en) opt.textContent = (lang === "fr") ? fr : en;
        });
      });

      // Rebuild WhatsApp link with language-friendly text
      setWhatsAppLinks();
    }

    btnFR.addEventListener("click", ()=>applyLang("fr"));
    btnEN.addEventListener("click", ()=>applyLang("en"));


<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>RAM6 Premium Cleaning — Turnover Airbnb | Casablanca & Dar Bouazza</title>
  <meta name="description" content="RAM6 Premium Cleaning : ménage turnover premium pour locations courte durée (Airbnb/Booking) à Casablanca & Dar Bouazza. Checklist, photos fin de prestation, option linge & consommables." />

  <style>
    :root{
      /* Premium + calme (propreté / confiance) */
      --bg: #F7FAFC;
      --surface: #FFFFFF;
      --ink: #0B1320;
      --muted: #5B677A;
      --line: rgba(10, 25, 47, .10);

      --navy: #0A1930;
      --teal: #1AA6A6;
      --teal2:#0E7C7B;
      --soft: #EEF4F6;
      --shadow: 0 10px 30px rgba(10,25,47,.08);
      --radius: 18px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
      background: radial-gradient(1100px 700px at 10% 0%, rgba(26,166,166,.08), transparent 55%),
                  radial-gradient(900px 600px at 90% 10%, rgba(10,25,48,.06), transparent 60%),
                  var(--bg);
      color: var(--ink);
    }
    a{color:inherit}
    .wrap{max-width:1100px;margin:0 auto;padding:24px}
    .nav{
      display:flex;align-items:center;justify-content:space-between;gap:12px;
      padding:14px 0;
    }
    .brand{
      display:flex;align-items:center;gap:12px;
      font-weight:900; letter-spacing:.2px;
    }
    .logoMark{
      width:36px;height:36px;border-radius:12px;
      background: linear-gradient(135deg, rgba(26,166,166,.95), rgba(10,25,48,.95));
      box-shadow: 0 12px 22px rgba(10,25,47,.12);
      display:grid;place-items:center;color:#fff;font-weight:900;
      font-size:14px;
      flex:0 0 auto;
    }
    .badge{
      font-size:12px;padding:5px 10px;border:1px solid var(--line);
      border-radius:999px;color:var(--muted); background: rgba(255,255,255,.7);
      white-space:nowrap;
    }
    .links{display:flex;gap:14px;flex-wrap:wrap;align-items:center;justify-content:flex-end}
    .links a{opacity:.9;text-decoration:none;font-size:14px;color:var(--muted)}
    .links a:hover{opacity:1;color:var(--ink);text-decoration:underline}

    /* Language toggle */
    .lang{
      display:flex;gap:6px;align-items:center;
      padding:6px;border:1px solid var(--line);border-radius:999px;
      background: rgba(255,255,255,.75);
      box-shadow: 0 8px 18px rgba(10,25,47,.06);
    }
    .lang button{
      border:0;background:transparent;cursor:pointer;
      padding:8px 10px;border-radius:999px;font-weight:800;font-size:13px;
      color:var(--muted);
    }
    .lang button.active{
      background: linear-gradient(135deg, rgba(26,166,166,.14), rgba(10,25,48,.04));
      color:var(--navy);
      border:1px solid rgba(26,166,166,.30);
    }

    .hero{
      padding:26px 0 8px;
      display:grid;
      grid-template-columns: 1.2fr .8fr;
      gap:16px; align-items:stretch;
    }
    @media (max-width:900px){ .hero{grid-template-columns:1fr} }

    .card{
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px;
    }

    .heroCard{
      padding:22px;
      border-radius: calc(var(--radius) + 2px);
      background:
        linear-gradient(180deg, rgba(26,166,166,.08), rgba(10,25,48,.03)),
        var(--surface);
    }

    h1{
      margin:0 0 8px;
      font-size: 40px;
      line-height: 1.08;
      letter-spacing: -0.6px;
      color: var(--navy);
    }
    @media (max-width:520px){ h1{font-size:32px} }

    .sub{
      margin:0 0 14px;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.55;
    }

    .pillRow{display:flex;gap:8px;flex-wrap:wrap;margin:14px 0}
    .pill{
      border:1px solid var(--line);
      border-radius:999px;
      padding:8px 10px;
      font-size:13px;
      color: var(--muted);
      background: rgba(255,255,255,.75);
    }

    .ctaRow{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}
    .btn{
      border: 1px solid var(--line);
      background: #fff;
      color: var(--navy);
      padding: 11px 14px;
      border-radius: 14px;
      text-decoration:none;
      font-weight: 900;
      font-size: 14px;
      display:inline-flex; align-items:center; gap:10px;
      box-shadow: 0 8px 18px rgba(10,25,47,.06);
      transition: transform .12s ease, box-shadow .12s ease;
      cursor:pointer;
    }
    .btn:hover{transform: translateY(-1px); box-shadow: 0 12px 22px rgba(10,25,47,.10)}
    .btn.primary{
      background: linear-gradient(135deg, rgba(26,166,166,.14), rgba(10,25,48,.05));
      border-color: rgba(26,166,166,.35);
    }
    .btn.wa{
      background: linear-gradient(135deg, rgba(26,166,166,.20), rgba(14,124,123,.06));
      border-color: rgba(14,124,123,.35);
    }
    .iconDot{
      width:10px;height:10px;border-radius:99px;background: var(--teal);
      box-shadow: 0 0 0 4px rgba(26,166,166,.12);
    }

    .side .kpi{display:grid;grid-template-columns:1fr 1fr; gap:10px}
    .kpi .box{
      background: linear-gradient(180deg, rgba(238,244,246,.85), rgba(255,255,255,.90));
      border:1px solid var(--line);
      border-radius: 16px;
      padding: 12px;
    }
    .kpi .n{font-size:18px;font-weight:950;color:var(--navy)}
    .kpi .t{font-size:12px;color:var(--muted);margin-top:2px}

    .section{padding:18px 0}
    h2{margin:0 0 10px;font-size:22px;color:var(--navy)}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    @media (max-width:900px){ .grid{grid-template-columns:1fr} }
    .card h3{margin:0 0 8px;font-size:16px;color:var(--navy)}
    .card p{margin:0;color:var(--muted);font-size:14px;line-height:1.6}
    .list{margin:10px 0 0;padding-left:16px;color:var(--muted);font-size:14px;line-height:1.6}

    .pricing{display:grid;grid-template-columns:1.2fr .8fr; gap:12px}
    @media (max-width:900px){ .pricing{grid-template-columns:1fr} }

    table{width:100%;border-collapse:collapse;font-size:14px}
    th,td{border-bottom:1px solid var(--line);padding:10px 8px;text-align:left}
    th{color:var(--muted);font-weight:900}

    .note{color:var(--muted);font-size:13px;line-height:1.55;margin-top:8px}

    .form{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px}
    @media (max-width:700px){ .form{grid-template-columns:1fr} }
    input,select,textarea{
      width:100%;
      padding: 12px 12px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(238,244,246,.75);
      color: var(--ink);
      font-size: 14px;
      outline: none;
    }
    textarea{min-height:110px; resize:vertical}
    .footer{
      padding: 22px 0;
      color: var(--muted);
      font-size: 13px;
      border-top: 1px solid var(--line);
      margin-top: 12px;
    }
    .small{font-size:12px;color:var(--muted)}

    /* Language blocks */
    [data-lang]{display:none}
    [data-lang].on{display:block}

    /* Small helper badge inside sections */
    .miniBadge{
      display:inline-block;
      font-size:12px;
      padding:5px 10px;
      border-radius:999px;
      background: rgba(26,166,166,.10);
      border:1px solid rgba(26,166,166,.25);
      color: var(--navy);
      font-weight:900;
      margin-bottom:10px;
    }
  </style>
</head>

